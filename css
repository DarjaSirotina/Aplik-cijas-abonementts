body {
    font-family: Arial;
    background-color: #eef2f7;
    text-align: center;
}

.container {
    background: white;
    padding: 20px;
    margin: 20px auto;
    width: 320px;
    border-radius: 10px;
}

button {
    margin-top: 10px;
    padding: 10px;
    background-color: #007BFF;
    color: white;
    border: none;
    cursor: pointer;
}

button:hover {
    background-color: #0056b3;
}
